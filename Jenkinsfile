pipeline {
  agent any
  stages {
    stage('Clone')
    {
      steps {
        echo 'Cloning repository'
      }
    }
    stage('Input')
    {
      steps {
        input ('Do you want to proceed?')
      }
    }
    stage('Build')
    {
      steps {
        echo 'Building'
      }

        
    
   }
  }
}

